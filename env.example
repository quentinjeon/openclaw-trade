# ============================================
# OpenClaw Trading System 환경변수 예제
# 이 파일을 .env로 복사하고 실제 값을 채워넣으세요
# cp env.example .env
# ============================================

# 앱 설정
APP_NAME="OpenClaw Trading System"
DEBUG=false
ENVIRONMENT=development

# 서버
HOST=0.0.0.0
PORT=8000
CORS_ORIGINS=http://localhost:3000

# 데이터베이스
DATABASE_URL=sqlite+aiosqlite:///./openclaw.db

# 거래 설정 (안전을 위해 PAPER_TRADING=true로 시작)
PAPER_TRADING=true
DEFAULT_EXCHANGE=binance
DEFAULT_SYMBOLS=BTC/USDT,ETH/USDT
PAPER_TRADING_BALANCE=10000.0

# 거래소 API 키 (실거래 시 필요, git에 절대 커밋 금지!)
BINANCE_API_KEY=your_binance_api_key_here
BINANCE_SECRET_KEY=your_binance_secret_key_here
BINANCE_TESTNET=true

# 리스크 설정
MAX_POSITION_SIZE_PCT=5.0
MAX_OPEN_POSITIONS=5
DAILY_LOSS_LIMIT_PCT=3.0
DEFAULT_STOP_LOSS_PCT=2.0
DEFAULT_TAKE_PROFIT_PCT=4.0

# 전략 설정
RSI_PERIOD=14
RSI_OVERSOLD=30.0
RSI_OVERBOUGHT=70.0
MACD_FAST=12
MACD_SLOW=26
MACD_SIGNAL=9

# 프론트엔드
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000
