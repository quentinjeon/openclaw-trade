# ============================================
# OpenClaw Trading System 환경변수 예제
# 이 파일을 .env로 복사하고 실제 값을 채워넣으세요
# cp env.example .env
# ============================================

# 앱 설정
APP_NAME="OpenClaw Trading System"
DEBUG=false
ENVIRONMENT=development

# 서버
HOST=0.0.0.0
PORT=8000
CORS_ORIGINS=["http://localhost:3001"]

# 데이터베이스
DATABASE_URL=sqlite+aiosqlite:///./openclaw.db

# ── 실거래 (기본) ─────────────────────────────
# false = Binance 현물 메인넷 실계좌 (API 키 필수). 대시보드·포트폴리오는 거래소 잔고 동기화.
# true = 가상 체결만 (개발용)
PAPER_TRADING=false
BINANCE_TESTNET=false
# true=대시보드 승인 후 매수 체결 | false=승인 없이 즉시 체결(매도 자동청산은 별도)
MANUAL_ORDER_APPROVAL=true
# 기동 시 TRX→USDT 전량 매도(있을 때만) + 전략·리스크 에이전트 포함 가동. TRX 재보유 시 재기동 전 false 권장.
STARTUP_BOOTSTRAP_TRADING=true
# orderbook=호가 지정가(매수 bid·매도 ask, 최대 대기 ORDER_FILL_MAX_WAIT_SEC) | market=시장가
ORDER_EXECUTION_MODE=orderbook
ORDER_FILL_MAX_WAIT_SEC=120
ORDER_FILL_POLL_INTERVAL_SEC=1.5
# 매수 예산 = 거래소 free 쿼트 × (1 - 이 비율). 명목가 부족으로 주문 실패 방지
CASH_FEE_RESERVE_PCT=0.35
ORDER_MIN_NOTIONAL_FALLBACK_USD=5
DEFAULT_EXCHANGE=binance

# 거래소 API 키 (실거래 시 필수, git 커밋 금지)
BINANCE_API_KEY=
BINANCE_SECRET_KEY=

# OpenAI (LLM Text-to-Rule — 기본 OFF)
# OPENAI_API_KEY=
# OPENAI_MAX_SPEND_USD=30
# OPENAI_LLM_ENABLED=false

# 에이전트 분석 대상 (미설정 시 core/symbol_lists.py 기본)
# DEFAULT_SYMBOLS=["BTC/USDT","ETH/USDT"]

# 페이퍼 모드 전용 가상 잔고 (PAPER_TRADING=true 일 때만)
PAPER_TRADING_BALANCE=10000.0

# 리스크 설정
MAX_POSITION_SIZE_PCT=5.0
MAX_OPEN_POSITIONS=5
DAILY_LOSS_LIMIT_PCT=3.0
DEFAULT_STOP_LOSS_PCT=2.0
DEFAULT_TAKE_PROFIT_PCT=4.0

# 전략 설정
RSI_PERIOD=14
RSI_OVERSOLD=30.0
RSI_OVERBOUGHT=70.0
MACD_FAST=12
MACD_SLOW=26
MACD_SIGNAL=9

# 프론트엔드
NEXT_PUBLIC_API_URL=http://localhost:8002
NEXT_PUBLIC_WS_URL=ws://localhost:8002
